{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",          
    "moduleResolution": "NodeNext",
    "outDir": "./dist",            
    "rootDir": "./",
    "strict": true,                
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true              
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}


 